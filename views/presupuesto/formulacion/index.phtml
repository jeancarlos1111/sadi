                $totalAsignado += $pg->montoAsignado;
                $totalComprometido += $pg->montoComprometido;
                $totalDisponible += $disponible;
                $colorDisp = $disponible < 0 ? 'red' : ($disponible < ($pg->montoAsignado * 0.10) ? 'orange' : 'green');
            ?>
            <tr>
                <td><?= htmlspecialchars($data['estructura_desc']) ?></td>
                <td><code><?= htmlspecialchars($data['partida_codigo']) ?></code></td>
                <td><?= htmlspecialchars($data['partida_desc']) ?></td>
                <td style="text-align: right;"><?= number_format($pg->montoAsignado, 2, ',', '.') ?></td>
                <td style="text-align: right; color: orange;"><?= number_format($pg->montoComprometido, 2, ',', '.') ?></td>
                <td style="text-align: right; color: #dc3545;"><?= number_format($pg->montoCausado, 2, ',', '.') ?></td>
                <td style="text-align: right; font-weight: bold; color: <?= $colorDisp ?>;">
                    <?= number_format($disponible, 2, ',', '.') ?>
                </td>
                <td>
                    <a href="?route=presupuesto/form&id=<?= $pg->id ?>" style="margin-right: 8px;">Editar</a>
                    <form method="POST" action="?route=presupuesto/eliminar" onsubmit="return confirm('¿Eliminar esta partida presupuestaria?');" style="display:inline;">
                        <input type="hidden" name="id" value="<?= $pg->id ?>">
                        <button type="submit" style="color: red; border:none; background:none; cursor:pointer;">Eliminar</button>
                    </form>
                </td>
            </tr>
