            <script>
            function seleccionarSolicitud(id, concepto, monto) {
                document.getElementById('inp_id_solicitud').value = id;
                document.getElementById('lbl_concepto').textContent = concepto;
                document.getElementById('lbl_monto').textContent = monto.toLocaleString('es-VE', {minimumFractionDigits: 2});
                document.getElementById('pago-placeholder').style.display = 'none';
                document.getElementById('pago-form').style.display = 'block';
                // Resaltar fila seleccionada
                document.querySelectorAll('tr[id^="sol-"]').forEach(r => r.classList.remove('table-active'));
                const row = document.getElementById('sol-' + id);
                if (row) row.classList.add('table-active');
            }
            function cancelarSeleccion() {
                document.getElementById('pago-placeholder').style.display = 'block';
                document.getElementById('pago-form').style.display = 'none';
                document.querySelectorAll('tr[id^="sol-"]').forEach(r => r.classList.remove('table-active'));
            }
            </script>
