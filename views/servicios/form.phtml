<h2><?= htmlspecialchars($titulo) ?></h2>

<?php if (isset($error)): ?><div style="color:red; padding:10px; border:1px solid red; margin-bottom:20px;"><?= htmlspecialchars($error) ?></div><?php endif; ?>

<form method="POST" action="?route=servicios/guardar" style="max-width:500px;">
    <?php if ($item && $item->id): ?><input type="hidden" name="id" value="<?= $item->id ?>"><?php endif; ?>

    <div style="margin-bottom:10px;">
        <label>Denominación (*):</label><br>
        <input type="text" name="denominacion" value="<?= htmlspecialchars($item->denominacion ?? '') ?>" required maxlength="100" style="width:100%; padding:5px;">
    </div>
    <div style="margin-bottom:10px;">
        <label>Tipo de Servicio (*):</label><br>
        <select name="id_tipo_servicio" required style="width:100%; padding:5px;">
            <option value="">SELECCIONE</option>
            <?php foreach ($tiposServicio as $ts): ?>
                <option value="<?= $ts->id ?>" <?= ($item && $item->idTipoServicio === $ts->id) ? 'selected' : '' ?>>
                    <?= htmlspecialchars($ts->denominacion) ?>
                </option>
            <?php endforeach; ?>
        </select>
    </div>
    <div style="margin-bottom:10px;">
        <label>Partida Presupuestaria de Gastos (opcional):</label><br>
        <select name="id_codigo_plan_unico" style="width:100%; padding:5px;">
            <option value="">-- No Asignada --</option>
            <?php foreach ($cuentas as $c): ?>
                <option value="<?= $c->id ?>" <?= ($item && $item->idCodigoPlanUnico === $c->id) ? 'selected' : '' ?>>
                    <?= htmlspecialchars($c->codigo . ' - ' . $c->denominacion) ?>
                </option>
            <?php endforeach; ?>
        </select>
    </div>
    <div style="margin-bottom:10px;">
        <label>Descripción:</label><br>
        <input type="text" name="descripcion" value="<?= htmlspecialchars($item->descripcion ?? '') ?>" maxlength="200" style="width:100%; padding:5px;">
    </div>
    <div style="margin-bottom:20px;">
        <label>
            <input type="checkbox" name="aplicar_iva" value="1" <?= ($item && $item->aplicarIva) ? 'checked' : '' ?>>
            Aplica IVA
        </label>
    </div>
    <div>
        <button type="submit" style="padding:10px 20px; background-color:#28a745; color:white; border:none; cursor:pointer;">Guardar</button>
        <a href="?route=servicios/index" style="margin-left:10px; color:#dc3545;">Cancelar</a>
    </div>
</form>
