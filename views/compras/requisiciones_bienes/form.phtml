            <!-- In SIGAFS this was selected via an Ajax popup, but keeping it simple as ID for the MVC example -->
            <input type="number" name="id_estructura_presupuestaria" value="<?= htmlspecialchars((string)($requisicion->idEstructuraPresupuestaria ?? '')) ?>" required style="width: 100%; padding: 5px;">
