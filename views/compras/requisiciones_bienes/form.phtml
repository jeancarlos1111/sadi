                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
        <button type="button" onclick="agregarArticulo()">+ Añadir Fila</button>

        <script>
        function agregarArticulo() {
            var tbody = document.querySelector("#tabla-articulos tbody");
            var firstRow = tbody.querySelector("tr").cloneNode(true);
            firstRow.querySelector('select').value = "";
            firstRow.querySelector('input').value = "";
            tbody.appendChild(firstRow);
        }
        </script>
