    </fieldset>

    <fieldset style="margin-bottom: 20px;">
        <legend>Artículos Solicitados</legend>
        <table border="1" style="width: 100%; border-collapse: collapse; margin-bottom: 10px;" id="tabla-articulos">
            <thead style="background-color: #eee;">
                <tr>
                    <th>Artículo</th>
                    <th>Cantidad</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <?php 
                $listaArticulosRow = $requisicion ? $requisicion->articulos : [['id_articulo' => '', 'cantidad' => '']];
                foreach ($listaArticulosRow as $index => $art): 
                ?>
                <tr>
                    <td>
                        <select name="articulos[]" required style="width: 100%; padding: 5px;">
                            <option value="">SELECCIONE UN ARTICULO</option>
                            <?php foreach($articulosCatalogo as $catData): $cat = $catData['entity']; ?>
                                <option value="<?= $cat->id ?>" <?= ($cat->id == $art['id_articulo']) ? 'selected' : '' ?>>
                                    <?= htmlspecialchars($cat->denominacion) ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                    </td>
                    <td>
                        <input type="number" step="0.01" name="cantidades[]" value="<?= htmlspecialchars((string)($art['cantidad'] ?? '')) ?>" required style="width: 100%; padding: 5px;">
                    </td>
                    <td>
                        <button type="button" onclick="this.parentElement.parentElement.remove()" style="color: red; cursor:pointer;">Quitar</button>
