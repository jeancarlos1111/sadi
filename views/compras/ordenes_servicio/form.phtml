<script>
const opcionesServicios = `<?php foreach ($serviciosCatalogo as $sd): $s = $sd['entity']; ?><option value="<?= $s->id ?>" data-iva="<?= $s->aplicarIva ? '1' : '0' ?>"><?= htmlspecialchars($s->denominacion) ?></option><?php endforeach; ?>`;
let rowIdx = 1;

function vincularEventos(tr) {
    const sel = tr.querySelector('.sel-servicio');
    const chk = tr.querySelector('.chk-iva');
    const hid = tr.querySelector('.hid-iva');
    const cant = tr.querySelector('.inp-cant');
    const costo = tr.querySelector('.inp-costo');
    const btnDel = tr.querySelector('.btn-eliminar');

    sel.addEventListener('change', function() {
        const opt = sel.options[sel.selectedIndex];
        if (opt && opt.dataset.iva === '1') {
            chk.checked = true; hid.value = '1';
        } else {
            chk.checked = false; hid.value = '0';
        }
        calcularTotales();
    });

    [cant, costo].forEach(inp => inp.addEventListener('input', calcularTotales));

    if (btnDel) {
        btnDel.addEventListener('click', function() {
            tr.remove();
            calcularTotales();
        });
    }
}

document.getElementById('btnAgregar').addEventListener('click', function() {
    const tr = document.createElement('tr');
    tr.className = 'renglon';
    tr.innerHTML = `
        <td>
            <select name="id_servicio[]" class="form-control form-control-sm sel-servicio" required>
                <option value="">-- Seleccione --</option>
                ${opcionesServicios}
            </select>
        </td>
        <td class="text-center align-middle">
            <input type="hidden" name="aplica_iva[]" class="hid-iva" value="0">
            <div class="custom-control custom-checkbox ml-2">
                <input type="checkbox" class="custom-control-input chk-iva" id="chk_iva_${rowIdx}" disabled>
                <label class="custom-control-label" for="chk_iva_${rowIdx}"></label>
            </div>
        </td>
        <td>
            <input type="number" name="cantidad_sods[]" value="1" min="0.01" step="0.01" class="form-control form-control-sm inp-cant" required>
        </td>
        <td>
            <input type="number" name="costo_sods[]" value="0" min="0" step="0.01" class="form-control form-control-sm inp-costo" required>
        </td>
        <td class="text-right align-middle font-weight-bold td-total">0.00</td>
        <td class="text-center align-middle">
            <button type="button" class="btn btn-sm btn-danger btn-eliminar" title="Quitar renglón">
                <i class="fas fa-times"></i>
            </button>
        </td>
    `;
    document.getElementById('cuerpoServicios').appendChild(tr);
    vincularEventos(tr);
    rowIdx++;
});

function calcularTotales() {
    let base = 0;
    let baseConIva = 0;
    document.querySelectorAll('.renglon').forEach(tr => {
        const cant = parseFloat(tr.querySelector('.inp-cant').value) || 0;
        const costo = parseFloat(tr.querySelector('.inp-costo').value) || 0;
        const totalLinea = cant * costo;
        tr.querySelector('.td-total').textContent = totalLinea.toFixed(2);
        
        base += totalLinea;
        if (tr.querySelector('.chk-iva').checked) {
            baseConIva += totalLinea;
        }
    });

    const pctIva = parseFloat(document.getElementById('porcentaje_iva_os').value) || 0;
    const montoIva = baseConIva * (pctIva / 100);
    const montoTotal = base + montoIva;

    document.getElementById('monto_base_os').value = base.toFixed(2);
    document.getElementById('monto_iva_os').value = montoIva.toFixed(2);
    document.getElementById('monto_total_os').value = montoTotal.toFixed(2);
}

document.querySelectorAll('.renglon').forEach(tr => {
    // Vincular el botón de eliminación predeterminado si existe
    const btnDel = tr.querySelector('.btn-eliminar');
    if(btnDel) {
        btnDel.addEventListener('click', function() {
            tr.remove();
            calcularTotales();
        });
    }
    vincularEventos(tr);
});
</script>
