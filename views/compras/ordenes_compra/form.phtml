<script>
    // Datos de artículos pasados desde PHP a JS
    const catalogoArticulos = [
        <?php foreach ($articulos as $art): ?>
            <?php $a = $art['entity']; ?>
            { id: <?= $a->id ?>, nombre: "<?= addslashes($a->denominacion) ?>", partida: "<?= addslashes($art['partida'] ?? 'Sin Partida') ?>", aplica_iva: <?= $a->aplicarIva ? 'true' : 'false' ?> },
        <?php endforeach; ?>
    ];

    const tabla = document.querySelector('#tablaArticulos tbody');
    const btnAgregar = document.getElementById('btnAgregarArticulo');
    
    function calcularTotales() {
        let base_imponible = 0;
        let monto_iva = 0;
        const porcentaje_iva = parseFloat(document.getElementById('porcentaje_iva_odc').value) || 0;

        const filas = tabla.querySelectorAll('tr');
        filas.forEach(fila => {
            const cantidad = parseFloat(fila.querySelector('.input-cantidad').value) || 0;
            const costo = parseFloat(fila.querySelector('.input-costo').value) || 0;
            const chkIva = fila.querySelector('.cb-fake');
            const aplicaIva = chkIva ? chkIva.checked : false;
            
            const subtotal = cantidad * costo;
            fila.querySelector('.lbl-subtotal').textContent = subtotal.toFixed(2);
            
            base_imponible += subtotal;
            if (aplicaIva) {
                monto_iva += subtotal * (porcentaje_iva / 100);
            }
        });

        const total = base_imponible + monto_iva;

        // Actualizar UI
        document.getElementById('lbl_monto_base').textContent = base_imponible.toFixed(2);
        document.getElementById('lbl_monto_iva').textContent = monto_iva.toFixed(2);
        document.getElementById('lbl_monto_total').textContent = total.toFixed(2);

        // Actualizar Hidden Inputs para el POST
        document.getElementById('monto_base_odc').value = base_imponible.toFixed(2);
        document.getElementById('monto_iva_odc').value = monto_iva.toFixed(2);
        document.getElementById('monto_total_odc').value = total.toFixed(2);
    }

    function agregarFila() {
        const tr = document.createElement('tr');
        
        let opcionesArticulos = '<option value="">-- Seleccione --</option>';
        catalogoArticulos.forEach(art => {
            opcionesArticulos += `<option value="${art.id}">${art.nombre} (Partida: ${art.partida})</option>`;
        });

        tr.innerHTML = `
            <td>
                <select name="id_articulo[]" class="input-articulo" required style="width: 100%; padding: 5px;">
                    ${opcionesArticulos}
                </select>
            </td>
            <td>
                <input type="number" step="0.01" name="cantidad_aodc[]" class="input-cantidad" value="1" required style="width: 100px; padding: 5px;">
            </td>
            <td>
                <input type="number" step="0.01" name="costo_aodc[]" class="input-costo" value="0" required style="width: 100px; padding: 5px;">
            </td>
            <td style="text-align: center;">
                <input type="checkbox" class="cb-fake">
                <input type="hidden" name="aplica_iva[]" class="input-aplica-iva-real" value="0">
            </td>
            <td style="text-align: right; font-weight: bold;">
                <span class="lbl-subtotal">0.00</span>
            </td>
            <td style="text-align: center;">
                <button type="button" class="btn-eliminar" style="color: red; background: none; border: none; cursor: pointer; font-size: 1.2em;">✖</button>
            </td>
        `;

        // Eventos
        const selArticulo = tr.querySelector('.input-articulo');
        const chkIva = tr.querySelector('.cb-fake');
        const hiddenIva = tr.querySelector('.input-aplica-iva-real');

        selArticulo.addEventListener('change', function() {
            const selectedVal = this.value;
            const articulo = catalogoArticulos.find(a => a.id == selectedVal);
            if (articulo && articulo.aplica_iva) {
                chkIva.checked = true;
                hiddenIva.value = '1';
            } else {
                chkIva.checked = false;
                hiddenIva.value = '0';
            }
            calcularTotales();
        });

        chkIva.addEventListener('change', function() {
            hiddenIva.value = this.checked ? '1' : '0';
            calcularTotales();
        });

        tr.querySelector('.input-cantidad').addEventListener('input', calcularTotales);
        tr.querySelector('.input-costo').addEventListener('input', calcularTotales);
        
        tr.querySelector('.btn-eliminar').addEventListener('click', function() {
            tr.remove();
            calcularTotales();
        });

        tabla.appendChild(tr);
    }

    btnAgregar.addEventListener('click', agregarFila);
    document.getElementById('porcentaje_iva_odc').addEventListener('input', calcularTotales);

    // Agregar una fila vacía por defecto al iniciar
    agregarFila();

</script>
