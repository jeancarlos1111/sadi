<script>
const opcionesServicios = `<?php foreach ($serviciosCatalogo as $sd): $s = $sd['entity']; ?><option value="<?= $s->id ?>"><?= htmlspecialchars($s->denominacion) ?></option><?php endforeach; ?>`;
document.getElementById('btnAgregar').addEventListener('click', function() {
    const tr = document.createElement('tr');
    tr.innerHTML = `
        <td>
            <select name="servicios[]" class="form-control form-control-sm select2" required>
                <option value="">-- Seleccione --</option>
                ${opcionesServicios}
            </select>
        </td>
        <td>
            <input type="number" name="cantidades[]" class="form-control form-control-sm text-center" value="1" min="0.01" step="0.01" required>
        </td>
        <td class="text-center align-middle">
            <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('tr').remove()" title="Quitar">
                <i class="fas fa-times"></i>
            </button>
        </td>
    `;
    document.getElementById('cuerpoServicios').appendChild(tr);
});
</script>
