<script>
document.addEventListener('DOMContentLoaded', function() {
    const btnAdd = document.getElementById('btn-add-indicador');
    const tbody = document.querySelector('#tabla-indicadores tbody');

    btnAdd.addEventListener('click', function() {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td><textarea class="form-control" name="ind_eficacia[]" rows="2"></textarea></td>
            <td><textarea class="form-control" name="ind_eficiencia[]" rows="2"></textarea></td>
            <td><textarea class="form-control" name="ind_calidad[]" rows="2"></textarea></td>
            <td><textarea class="form-control" name="ind_impacto[]" rows="2"></textarea></td>
            <td><textarea class="form-control" name="ind_medio[]" rows="2"></textarea></td>
            <td><button type="button" class="btn btn-danger btn-sm btn-remove-ind"><i class="fas fa-trash"></i></button></td>
        `;
        tbody.appendChild(tr);
    });

    tbody.addEventListener('click', function(e) {
        if (e.target.closest('.btn-remove-ind')) {
            const row = e.target.closest('tr');
            if (tbody.querySelectorAll('tr').length > 1) {
                row.remove();
            } else {
                alert('Debe mantener al menos un indicador');
            }
        }
    });
});
</script>
