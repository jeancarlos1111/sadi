<script>
// Plantilla HTML de una fila nueva (datos del servidor serializados)
const estructurasOpts = <?= json_encode(array_map(fn($ep) => ['id' => $ep->id, 'desc' => $ep->descripcion], $estructuras)) ?>;
const cuentasOpts     = <?= json_encode(array_map(fn($cpu) => ['id' => $cpu->id, 'label' => $cpu->codigo . ' – ' . $cpu->denominacion], $planCuentas)) ?>;

function buildSelect(name, opts, labelKey) {
    let s = `<select name="${name}[]" style="width:100%; padding:4px;" required><option value="">-- seleccione --</option>`;
    opts.forEach(o => { s += `<option value="${o.id}">${o[labelKey]}</option>`; });
    s += '</select>';
    return s;
}

function agregarLinea() {
    const tbody = document.getElementById('cuerpo-lineas');
    const tr = document.createElement('tr');
    tr.className = 'linea-detalle';
    tr.innerHTML = `
        <td>${buildSelect('id_estruc', estructurasOpts, 'desc')}</td>
        <td>${buildSelect('id_cuenta', cuentasOpts, 'label')}</td>
        <td><input type="number" name="monto[]" step="0.01" min="0.01" style="width:100%; padding:4px; text-align:right;" placeholder="0.00" required></td>
        <td><input type="text" class="form-control" name="descripcion_linea[]" maxlength="255" placeholder="Descripción opcional"></td>
        <td class="text-center align-middle"><button type="button" onclick="quitarLinea(this)" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button></td>
    `;
    tbody.appendChild(tr);
}

function quitarLinea(btn) {
    const tbody = document.getElementById('cuerpo-lineas');
    if (tbody.querySelectorAll('tr.linea-detalle').length > 1) {
        btn.closest('tr').remove();
    } else {
        alert('Debe haber al menos una línea de detalle.');
    }
}

function consultarDisponible(e) {
    e.preventDefault();
    const filas = document.querySelectorAll('#cuerpo-lineas tr.linea-detalle');
    const resultDiv = document.getElementById('disponibilidad-resultado');
    let html = '<strong>Disponibilidad presupuestaria consultada:</strong><ul style="margin:4px 0;">';
    let promesas = [];
    filas.forEach(fila => {
        const ep    = fila.querySelector('select[name="id_estruc[]"]').value;
        const cpu   = fila.querySelector('select[name="id_cuenta[]"]').value;
        if (ep && cpu) {
            promesas.push(
                fetch(`?route=comprobante_presupuesto/disponibilidad&id_estruc=${ep}&id_cuenta=${cpu}`)
                    .then(r => r.json())
                    .then(data => {
                        const epLabel  = fila.querySelector('select[name="id_estruc[]"] option:checked').text;
                        const cpuLabel = fila.querySelector('select[name="id_cuenta[]"] option:checked').text;
                        const color = data.disponible >= 0 ? 'green' : 'red';
                        html += `<li>${epLabel} / ${cpuLabel}: <strong style="color:${color}">Bs. ${parseFloat(data.disponible).toLocaleString('es-VE', {minimumFractionDigits:2})}</strong></li>`;
                    })
            );
        }
    });
    Promise.all(promesas).then(() => {
        html += '</ul>';
        resultDiv.innerHTML = html;
        resultDiv.style.display = 'block';
    });
}
</script>
