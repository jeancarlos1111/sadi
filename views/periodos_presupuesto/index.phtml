<form method="POST" action="?route=periodos_presupuesto/guardar">
    <input type="hidden" name="anio" value="<?= htmlspecialchars((string)$anio) ?>">

    <table border="1" cellpadding="10" cellspacing="0" style="width:100%; border-collapse:collapse; max-width:700px;">
        <thead style="background-color:#0056b3; color:white;">
            <tr>
                <th>Mes</th>
                <th style="text-align:center;">Estado Actual</th>
                <th style="text-align:center;">Cerrar Mes</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($periodos as $mes => $periodo): ?>
                <tr>
                    <td style="font-weight:bold;"><?= htmlspecialchars($periodo->nombreMes()) ?></td>
                    <td style="text-align:center;">
                        <?php if ($periodo->isAbierto()): ?>
                            <span style="color:green; font-weight:bold;">✅ ABIERTO</span>
                        <?php else: ?>
                            <span style="color:red; font-weight:bold;">🔒 CERRADO</span>
                            <?php if ($periodo->fecha_cierre): ?>
                                <small style="color:#666;"> (<?= htmlspecialchars($periodo->fecha_cierre) ?>)</small>
                            <?php endif; ?>
                        <?php endif; ?>
                    </td>
                    <td style="text-align:center;">
                        <input
                            type="checkbox"
                            name="meses_cerrados[]"
                            value="<?= $mes ?>"
                            <?= !$periodo->isAbierto() ? 'checked' : '' ?>
                            style="transform:scale(1.3); cursor:pointer;"
                        >
                    </td>
                </tr>
            <?php endforeach; ?>
        </tbody>
    </table>

    <div style="margin-top:15px;">
        <label>Observación (opcional):</label><br>
        <input type="text" name="observacion" maxlength="255" placeholder="Motivo del cierre/apertura..." style="width:100%; max-width:500px; padding:5px; margin-top:4px;">
    </div>

    <div style="margin-top:15px;">
        <button type="submit" style="padding:10px 20px; background-color:#dc3545; color:white; border:none; cursor:pointer;"
                onclick="return confirm('¿Confirmar los cambios de períodos?');">
            🔒 Aplicar Cierre / Apertura
        </button>
        <a href="?route=periodos_presupuesto/index&anio=<?= $anio ?>" style="margin-left:10px; color:#0056b3; text-decoration:underline;">Cancelar</a>
    </div>
</form>
