    <a href="?route=periodos_presupuesto/index&anio=<?= ($anio - 1) ?>" style="padding:5px 10px;">◀ <?= $anio - 1 ?></a>
    <a href="?route=periodos_presupuesto/index&anio=<?= ($anio + 1) ?>" style="padding:5px 10px;"><?= $anio + 1 ?> ▶</a>
