                $totalFormulado = 0;
                $totalRecaudado = 0;
                foreach ($formulado as $f): 
                    $totalFormulado += $f['monto_estimado_inicial'];
                    $totalRecaudado += $f['monto_recaudado'];
                    $porRecaudar = $f['monto_estimado_inicial'] - $f['monto_recaudado'];
