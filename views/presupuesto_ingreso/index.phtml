                    </td>
                    <td class="text-right align-middle font-weight-bold">Bs <?= number_format($f['monto_estimado_inicial'], 2, ',', '.') ?></td>
                    <td class="text-right align-middle font-weight-bold text-success">Bs <?= number_format($f['monto_recaudado'], 2, ',', '.') ?></td>
                    <td class="text-right align-middle font-weight-bold <?= $porRecaudar < 0 ? 'text-success' : 'text-danger' ?>">
                        Bs <?= number_format($porRecaudar, 2, ',', '.') ?>
                    </td>
                    <td class="text-center align-middle">
                        <div class="progress progress-sm">
                            <div class="progress-bar <?= $porcentaje >= 100 ? 'bg-success' : 'bg-primary' ?>" style="width: <?= min($porcentaje, 100) ?>%"></div>
                        </div>
                        <small>
                            <?= number_format($porcentaje, 1, ',', '.') ?>%
                        </small>
                    </td>
                </tr>
