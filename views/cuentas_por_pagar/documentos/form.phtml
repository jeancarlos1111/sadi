<script>
document.addEventListener('DOMContentLoaded', function() {
    const tipoOrigen = document.getElementById('tipo_origen');
    const idOrdenSelect = document.getElementById('id_orden_select');
    const formFactura = document.getElementById('formFactura');
    
    // Datos de órdenes pasados desde PHP para el cambio de select
    const ordenesCompra = <?= json_encode($ordenesCompra) ?>;
    const ordenesServicio = <?= json_encode($ordenesServicio) ?>;

    tipoOrigen.addEventListener('change', function() {
        const tipo = this.value;
        idOrdenSelect.innerHTML = '<option value="">-- Seleccione una orden --</option>';
        
        const lista = (tipo === 'compra') ? (ordenesCompra || []) : (ordenesServicio || []);
        lista.forEach(item => {
            const id = (tipo === 'compra') ? item.id_orden_de_compra : item.id_orden_de_servicio;
            const prefix = (tipo === 'compra') ? 'OC' : 'OS';
            const comp = item.compania_proveedor || 'Sin Empresa';
            const rif = item.rif_proveedor || 'Sin RIF';
            const opt = document.createElement('option');
            opt.value = id;
            opt.textContent = `${prefix} #${id} - ${comp} (${rif})`;
            idOrdenSelect.appendChild(opt);
        });
        
        resetCalculos();
    });

    idOrdenSelect.addEventListener('change', async function() {
        const id = this.value;
        if (!id) return;
        
        const tipo = tipoOrigen.value;
        try {
            const response = await fetch(`?route=documentos_por_pagar/getDatosOrden&id=${id}&tipo=${tipo}`);
            const data = await response.json();
            
            if (data) {
                document.getElementById('monto_base_d').value = data.monto_base_d;
                document.getElementById('monto_impuesto_d').value = data.monto_impuesto_d;
                document.getElementById('id_proveedor').value = data.id_proveedor;
                
                if (tipo === 'compra') {
                    document.getElementById('id_orden_de_compra').value = id;
                    document.getElementById('id_orden_de_servicio').value = '';
                } else {
                    document.getElementById('id_orden_de_servicio').value = id;
                    document.getElementById('id_orden_de_compra').value = '';
                }
                
                calcularTotales();
            }
        } catch (e) {
            console.error("Error al cargar datos de la orden", e);
        }
    });

    // Escuchar cambios en retenciones
    document.getElementById('porcentaje_retencion_iva').addEventListener('input', calcularTotales);
    document.getElementById('porcentaje_retencion_islr').addEventListener('input', calcularTotales);

    function calcularTotales() {
        const base = parseFloat(document.getElementById('monto_base_d').value) || 0;
        const iva = parseFloat(document.getElementById('monto_impuesto_d').value) || 0;
        const totalFactura = base + iva;
        
        const pIva = parseFloat(document.getElementById('porcentaje_retencion_iva').value) || 0;
        const pIslr = parseFloat(document.getElementById('porcentaje_retencion_islr').value) || 0;
        
        const montoRetIva = iva * (pIva / 100);
        const montoRetIslr = base * (pIslr / 100);
        
        const montoNeto = totalFactura - montoRetIva - montoRetIslr;

        // Formatear etiquetas
        document.getElementById('total_factura_label').textContent = formatBs(totalFactura);
        document.getElementById('monto_ret_iva').textContent = `Monto: ${formatBs(montoRetIva)}`;
        document.getElementById('monto_ret_islr').textContent = `Monto: ${formatBs(montoRetIslr)}`;
        document.getElementById('neto_pagar_label').textContent = formatBs(montoNeto);
    }

    function resetCalculos() {
        document.getElementById('monto_base_d').value = '';
        document.getElementById('monto_impuesto_d').value = '';
        document.getElementById('total_factura_label').textContent = 'Bs 0,00';
        document.getElementById('neto_pagar_label').textContent = 'Bs 0,00';
    }

    function formatBs(val) {
        return 'Bs ' + val.toLocaleString('es-VE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
});
</script>
