    <script>
        function calcularPagoFinal() {
            const base = parseFloat(document.getElementById('txtBase').value) || 0;
            const iva = parseFloat(document.getElementById('txtIva').value) || 0;
            const totalF = base + iva;

            const porcIslr = parseFloat(document.getElementById('cmbIslr').value) || 0;
            const porcIva = parseFloat(document.getElementById('cmbIva').value) || 0;

            const retIslr = base * (porcIslr / 100);
            const retIva = iva * (porcIva / 100);

            document.getElementById('lblRetIslr').textContent = retIslr.toFixed(2);
            document.getElementById('lblRetIva').textContent = retIva.toFixed(2);

            const retTotal = retIslr + retIva;
            const montoPago = totalF - retTotal;

            document.getElementById('lblTotalRetenido').textContent = "- " + retTotal.toFixed(2);
            document.getElementById('lblNeto').textContent = "Bs " + montoPago.toFixed(2);
        }

        document.getElementById('cmbIslr').addEventListener('change', calcularPagoFinal);
        document.getElementById('cmbIva').addEventListener('change', calcularPagoFinal);

        // Inicializar al cargar
        calcularPagoFinal();
    </script>
