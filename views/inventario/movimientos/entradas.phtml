                                    <?= htmlspecialchars($d['denominacion_a']) ?>
                                    <input type="hidden" name="id_articulo[]" value="<?= $d['id_articulo'] ?>">
                                </td>
                                <td><?= $d['tipo_tda'] == 1 ? 'Bien Nacional' : 'Insumo/Material' ?></td>
                                <td><?= htmlspecialchars($d['denominacion_udm']) ?></td>
                                <td><?= $pedida ?></td>
                                <td><?= $recibida ?></td>
                                <td style="font-weight: bold; color: <?= $porRecibir > 0 ? 'red' : 'green' ?>;">
