                            $porRecibir = $pedida - $recibida;
                            
                            if ($porRecibir > 0) $todoRecibido = false;
                        ?>
                            <tr <?= $porRecibir <= 0 ? 'style="background-color: #d4edda; color: #155724;"' : '' ?>>
