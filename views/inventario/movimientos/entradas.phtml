                <input type="hidden" name="id_orden" value="<?= $ordenSeleccionada['entity']->id ?>">
                
                <table border="1" cellpadding="8" cellspacing="0" style="width: 100%; border-collapse: collapse; margin-bottom: 15px; text-align: center;">
