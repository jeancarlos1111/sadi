{
    "name": "sadi/app",
    "description": "Sistema de Administración",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "amphp/postgres": "^2.2",
        "amphp/amp": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Sadi\\": "cli/src/"
        }
    },
    "bin": [
        "cli/sadi"
    ],
    "authors": [
        {
            "name": "SADI Dev"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "pestphp/pest": "^4.7"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
